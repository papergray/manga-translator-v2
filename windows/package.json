{
  "name": "manga-translator-windows",
  "version": "2.0.0",
  "description": "Manga Translator — AI-powered CBZ and web manga translation for Windows",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder --win --x64",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "tesseract.js": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.manga.translator",
    "productName": "Manga Translator",
    "copyright": "Copyright © 2025",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "public/**/*"],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Manga Translator"
    },
    "publish": null
  }
}
